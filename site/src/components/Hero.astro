---
import { runData, fmtOffset, recordedDate, transcriptEvents } from '../lib/run'

const clone = 'git clone https://github.com/itoonx/Auralis'
const events = transcriptEvents(11)
const d = runData.derived
---

<header class="mx-auto max-w-5xl px-6 pb-20 pt-24 text-center md:pt-32">
  <p class="font-mono text-xs tracking-widest text-lp-muted">auralis · the coordination layer for agent fleets</p>
  <h1 class="mx-auto mt-6 max-w-3xl text-balance font-sans text-5xl font-medium lowercase leading-tight text-lp-fg md:text-6xl">
    the model isn't the bottleneck. your shared state is.
  </h1>
  <p class="mx-auto mt-6 max-w-xl text-pretty text-lp-muted">
    we timed it: the LLM call is 99.9% of a fleet's wall-clock; coordination adds ~2.4ms. auralis
    makes shared state explicit, persistent, and never accidental — one brain, every agent, any
    runtime.
  </p>

  <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
    <code class="rounded border border-lp-border bg-lp-surface px-5 py-3 font-mono text-sm text-lp-fg">$ {clone}</code>
    <a
      href="https://github.com/itoonx/Auralis/blob/main/docs/proven.md"
      class="px-4 py-3 font-mono text-sm text-lp-muted underline-offset-4 hover:text-lp-fg hover:underline">read the proof →</a>
  </div>
  <p class="mt-3 font-mono text-xs text-lp-muted">
    running in five commands · no API key — workers reuse your Claude Code login
  </p>

  <!-- The Replay — a real recorded fleet run. Phase 2 animates this transcript
       against the log's virtual clock; the static render below is the
       reduced-motion / no-JS / crawler version and ships first. -->
  <figure class="mx-auto mt-14 max-w-4xl text-left">
    <div class="overflow-hidden rounded-md border border-lp-border bg-lp-surface">
      <div class="flex items-baseline justify-between gap-4 border-b border-lp-border px-4 py-2 font-mono text-xs text-lp-muted">
        <span>recorded {recordedDate} · {runData.eventCount} events · {d.workers} workers</span>
        <span class="hidden sm:inline">run {runData.runId}</span>
      </div>
      <ol class="overflow-x-auto px-4 py-3 font-mono text-xs leading-6 md:text-[13px]">
        {events.map((e) => (
          <li class="whitespace-nowrap">
            <span class="text-lp-muted">{fmtOffset(e.t)}</span>
            <span class:list={['ml-3', e.kind === 'overlap' ? 'text-lp-accent' : e.kind === 'finding' || e.kind === 'answer' ? 'text-lp-fg' : 'text-lp-muted']}>
              {(e.text ?? '').slice(0, 96)}{(e.text ?? '').length > 96 ? '…' : ''}
            </span>
          </li>
        ))}
      </ol>
      <div class="flex flex-wrap gap-x-6 gap-y-1 border-t border-lp-border px-4 py-2 font-mono text-xs text-lp-fg">
        <span>findings <b>{d.byKind.finding ?? 0}</b></span>
        <span>overlaps flagged <b>{d.overlapsFlagged}</b></span>
        <span>verified ✓ <b>{d.verified}</b></span>
        <span class="text-lp-muted">counters derived from the events above</span>
      </div>
    </div>
    <figcaption class="mt-2 text-center font-mono text-xs text-lp-muted">
      a real fleet run over this repository — recorded events, not a mockup
    </figcaption>
  </figure>
</header>
