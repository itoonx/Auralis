---
import Section from './Section.astro'

// the register here is an issue tracker: we file limits against ourselves —
// id, area, status — because "honest limits" is a claim too, and claims on
// this page come with receipts. every body sentence is lifted from docs/,
// not written for the landing page.
type Limit = {
  id: string
  area: string
  status: 'open' | 'resolved'
  title: string
  body: string
  proof?: { before: string; after: string; note: string }
}

const limits: Limit[] = [
  {
    id: 'LIM-01',
    area: 'evidence',
    status: 'open',
    title: 'the live numbers are n=1 directional',
    body: 'each headline figure is one non-deterministic run. pnpm bench reproduces any of them as mean ± spread; 50 deterministic tests in CI pin the mechanisms, not the magnitudes.',
  },
  {
    id: 'LIM-02',
    area: 'build mode',
    status: 'open',
    title: 'proven small, not scaled',
    body: 'clean decompositions, disjoint files, a handful of runs. overlapping-edit merges to a shared file are still ahead.',
  },
  {
    id: 'LIM-03',
    area: 'execution',
    status: 'open',
    title: 'v1 execution is confinement, not a true sandbox',
    body: 'writes must resolve inside the workspace and escapes are denied — but a container/vm sandbox is the real answer, and it sits on the roadmap.',
  },
  {
    id: 'LIM-04',
    area: 'recall',
    status: 'resolved',
    title: 'recall scored 53.4% — below full-context',
    body: 'the instrument was broken: 84% of losses were retrieval, not the reader. we fixed the instrument and re-ran the controlled baseline. the old number stays in the docs — pretending it never happened would defeat the point of this page.',
    proof: { before: '53.4%', after: '93.3%', note: 'memory 93.3% > full-context 90.0% > grep 60.0% · 12.9× fewer tokens' },
  },
]

const open = limits.filter((l) => l.status === 'open').length
const resolved = limits.length - open
---

<Section id="limits" title="honest limits">
  <p class="lm-intro -mt-4 mb-10 max-w-2xl text-pretty text-lp-muted">
    a proof page that hides its boundaries isn't proof. these are ours — filed like bugs, status
    included, because that's what they are.
  </p>

  <!-- the ledger -->
  <div class="max-w-3xl">
    <div class="flex items-baseline gap-3 font-mono text-xs text-lp-muted">
      <span class="tracking-widest">limits we file against ourselves</span>
      <span class="ml-auto whitespace-nowrap">{open} open · {resolved} resolved</span>
    </div>
    <ul class="mt-5 flex flex-col gap-4">
      {limits.map((l) => (
        <li class="lm-card rounded-2xl border border-lp-border bg-lp-surface p-5 transition-colors hover:border-lp-muted/40">
          <div class="flex items-center gap-3 font-mono text-xs text-lp-muted">
            <span>{l.id}</span>
            <span class="opacity-50" aria-hidden="true">·</span>
            <span>{l.area}</span>
            {l.status === 'open' ? (
              <span class="ml-auto inline-flex items-center gap-1.5 rounded-full border border-(--lp-warn)/30 px-2.5 py-0.5 text-(--lp-warn)">
                <span class="lm-dot h-1.5 w-1.5 rounded-full bg-(--lp-warn)" aria-hidden="true"></span>open
              </span>
            ) : (
              <span class="ml-auto inline-flex items-center gap-1.5 rounded-full border border-lp-accent/30 px-2.5 py-0.5 text-lp-accent">
                <span aria-hidden="true">✓</span>resolved
              </span>
            )}
          </div>
          <h3 class="mt-3 font-mono text-sm text-lp-fg">▸ {l.title}</h3>
          <p class="mt-2 text-sm text-pretty text-lp-muted">{l.body}</p>
          {l.proof && (
            <p class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 rounded-lg border border-lp-border bg-lp-surface-2/60 px-3 py-2 font-mono text-xs">
              <span class="text-lp-muted line-through opacity-60"><span class="sr-only">was </span>{l.proof.before}</span>
              <span class="text-lp-muted" aria-hidden="true">→</span>
              <span class="text-lp-accent"><span class="sr-only">now </span>{l.proof.after}</span>
              <span class="text-lp-muted">{l.proof.note}</span>
            </p>
          )}
        </li>
      ))}
    </ul>
  </div>
</Section>

<style>
  /* decoration only — the global reduced-motion kill flattens it */
  .lm-dot {
    animation: lm-blink 2.6s ease-in-out infinite;
  }
  @keyframes lm-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
</style>
