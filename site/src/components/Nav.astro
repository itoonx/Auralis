---
const links = [
  ['proof', '#proof'],
  ['architecture', '#architecture'],
  ['start', '#start'],
  ['docs', 'https://github.com/itoonx/Auralis/tree/main/docs'],
  ['github ↗', 'https://github.com/itoonx/Auralis'],
]
---

<nav class="sticky top-0 z-10 border-b border-lp-border bg-lp-bg/90 backdrop-blur" aria-label="main">
  <div class="mx-auto flex max-w-6xl items-baseline justify-between px-6 py-3">
    <a href="#top" class="font-sans text-sm font-medium lowercase text-lp-fg">auralis</a>
    <div class="flex gap-5 font-mono text-xs text-lp-muted">
      {links.map(([label, href]) => (
        <a class="underline-offset-4 hover:text-lp-fg hover:underline" href={href}>{label}</a>
      ))}
    </div>
  </div>
</nav>
