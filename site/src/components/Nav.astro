---
import Logo from './Logo.astro'

// install (the primary action) leads; proof always shows; architecture is the
// one that folds away below sm: on a narrow phone. github is an icon at the end.
const links: Array<[string, string, boolean?]> = [
  ['install', '#install'],
  ['proof', '#proof'],
  ['architecture', '#architecture', true],
]
const gh = 'https://github.com/itoonx/Auralis'
---

<!-- fixed, not sticky: the nav sits outside the ScrollSmoother wrapper, and
     sticky positioning can't track a transform-scrolled content block -->
<!-- glass nav: bg/90 made the blur invisible — a lower veil + stronger blur
     lets the particle field read through while text stays legible -->
<nav class="fixed inset-x-0 top-0 z-10 border-b border-lp-border bg-lp-bg/55 backdrop-blur-xl backdrop-saturate-150" aria-label="primary">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a href="#top" class="flex items-center gap-2.5 font-sans text-base font-medium lowercase text-lp-fg">
      <Logo class="h-[26px] w-[26px]" />auralis</a>
    <div class="flex items-center gap-3 font-mono text-xs text-lp-muted sm:gap-5">
      {links.map(([label, href, hideNarrow], i) => (
        <a
          class:list={[
            'underline-offset-4 hover:text-lp-fg hover:underline',
            i === 0 && 'text-lp-fg',
            hideNarrow && 'hidden sm:inline',
          ]}
          href={href}>{label}</a>
      ))}
      <a
        href={gh}
        class="text-lp-muted transition-colors hover:text-lp-fg"
        aria-label="auralis on github"
        title="github">
        <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.28-.01-1.04-.02-2.04-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.96 0-1.32.47-2.39 1.24-3.23-.12-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.23 0 4.63-2.81 5.65-5.49 5.95.43.37.82 1.1.82 2.22 0 1.6-.02 2.89-.02 3.29 0 .32.22.7.83.58C20.57 22.29 24 17.8 24 12.5 24 5.87 18.63.5 12 .5z"/>
        </svg>
      </a>
    </div>
  </div>
</nav>
