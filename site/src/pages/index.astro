---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import Problem from '../components/Problem.astro'
import Bet from '../components/Bet.astro'
import Proof from '../components/Proof.astro'
import Architecture from '../components/Architecture.astro'
import Memory from '../components/Memory.astro'
import Coordination from '../components/Coordination.astro'
import BuildMode from '../components/BuildMode.astro'
import Studio from '../components/Studio.astro'
import Mcp from '../components/Mcp.astro'
import GettingStarted from '../components/GettingStarted.astro'
import Limits from '../components/Limits.astro'
import Footer from '../components/Footer.astro'

const title = 'auralis — the coordination layer for ai agent fleets'
const description =
  'redundant work −53% on a live run. one shared, persistent brain + real-time coordination for fleets of AI coding agents — measured, not asserted.'
const canonical = new URL(Astro.url.pathname, Astro.site)

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'auralis',
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  license: 'https://github.com/itoonx/Auralis/blob/main/LICENSE',
  sameAs: ['https://github.com/itoonx/Auralis'],
})
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#101010" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body id="top">
    <Nav />
    <main>
      <Hero />
      <Problem />
      <Bet />
      <Proof />
      <Architecture />
      <Memory />
      <Coordination />
      <BuildMode />
      <Studio />
      <Mcp />
      <GettingStarted />
      <Limits />
    </main>
    <Footer />
  </body>
</html>
